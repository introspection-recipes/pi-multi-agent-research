{
  "name": "@introspection-recipes/pi-multi-agent-research",
  "version": "0.1.1",
  "description": "Anthropic's multi-agent research system (orchestrator-worker) reproduced as an Introspection (Pi) recipe.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "check": "npx -y -p @introspection-ai/pi-recipes@latest recipes check . --profile ci",
    "check:json": "npx -y -p @introspection-ai/pi-recipes@latest recipes check . --profile ci --json",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "pi": {
    "agents": [
      "./agents/*.yaml"
    ],
    "skills": [
      "./skills/*/SKILL.md"
    ],
    "extensions": [
      "./extensions/*.ts"
    ]
  }
}
