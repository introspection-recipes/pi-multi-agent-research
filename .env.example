# LLM provider — Anthropic (lead uses claude-opus-4-8, workers/citations use claude-sonnet-4-6).
# Needed when running the recipe directly / BYOK. Under managed llm_mode the platform
# supplies LLM access and this can be left blank.
ANTHROPIC_API_KEY=

# Web search (Parallel AI Search API) — used by extensions/web-tools.ts WebSearch tool.
# Required: WebSearch is the only data source the research system has.
# Get a key at https://parallel.ai
PARALLEL_API_KEY=

# Optional WebSearch tuning
# PARALLEL_SEARCH_PROCESSOR=base      # base | pro
# PARALLEL_SEARCH_MAX_RESULTS=5
